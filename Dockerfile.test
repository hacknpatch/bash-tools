ARG DISTRO=ubuntu:latest
FROM ${DISTRO}

# Install dependencies based on common package managers
RUN if command -v apt-get >/dev/null; then \
        apt-get update && apt-get install -y zstd lz4 git rsync tar bc coreutils procps && rm -rf /var/lib/apt/lists/*; \
    elif command -v dnf >/dev/null; then \
        dnf install -y zstd lz4 git rsync tar bc coreutils procps; \
    elif command -v yum >/dev/null; then \
        yum install -y zstd lz4 git rsync tar bc coreutils procps; \
    elif command -v apk >/dev/null; then \
        apk add --no-cache zstd lz4 git rsync tar bc coreutils procps bash; \
    fi

WORKDIR /app
COPY . .

# Run the test script
CMD ["bash", "code-compress/test.sh"]
